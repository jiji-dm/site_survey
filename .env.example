# ========================================
# Firebase Web SDK の設定値
# Firebase コンソール > プロジェクトの設定 > Web アプリ から取得して
# このファイルを `.env.local` にコピーして上書きしてください
# ========================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ========================================
# 認証で許可するメールアドレスのドメイン
# 複数指定したい場合はカンマ区切り
# 例) VITE_ALLOWED_DOMAINS=vacancorp.com,example.co.jp
# ========================================
VITE_ALLOWED_DOMAINS=vacancorp.com

# ========================================
# GitHub Pages にデプロイする際のベースパス
# 例) リポジトリ名が site_survey なら "/site_survey/"
# ローカル開発時は未設定でOK
# ========================================
# VITE_BASE=/site_survey/
